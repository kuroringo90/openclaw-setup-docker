# Tailscale Authentication Key
# Ottieni da: https://login.tailscale.com/admin/settings/keys
#
# Istruzioni:
# 1. Vai su Tailscale Admin Console
# 2. Settings → Keys → Generate auth key
# 3. Copia la key e incollala qui sotto
# 4. Rinomina questo file in .env

TS_AUTHKEY=

# Tailscale API Key (opzionale, per cleanup nodi duplicati)
# Ottieni da: https://login.tailscale.com/admin/settings/api
# Genera una API key con permessi di scrittura
TS_API_KEY=

# Tailscale Tailnet Name (opzionale, per cleanup nodi duplicati)
# Trovalo su: https://login.tailscale.com/admin/settings/dns
# È il nome della tua tailnet (es: tail12345678 o tua-email.com)
TS_TAILNET=
